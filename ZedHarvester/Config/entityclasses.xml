<configs>
    <set xpath="/entity_classes/entity_class[@name='zombieTemplateMale']/property[@name='TimeStayAfterDeath']/@value">60</set>

    <!-- Harvest drops do not appear to inherit from the zombie templates in V2.6,
         so apply them directly to every non-template humanoid zombie class. -->
    <append xpath="/entity_classes/entity_class[starts-with(@name,'zombie') and not(contains(@name,'Template'))]">
        <drop event="Harvest" name="foodRawMeat" count="0" tool_category="Butcher"/>
        <drop event="Harvest" name="foodRottingFlesh" tag="butcherHarvest" count="1,3"/>
        <drop event="Harvest" name="resourceBone" tag="butcherHarvest" count="1,3"/>
        <drop event="Harvest" name="resourceCloth" tag="butcherHarvest" count="1,3"/>
        <drop event="Harvest" name="oldCash" tag="butcherHarvest" count="1,5" loot_prob_template="low"/>
        <drop event="Harvest" name="resourceBone" tag="allToolsHarvest" count="1"/>
        <drop event="Harvest" name="foodRottingFlesh" count="1" tag="WasteTreasuresCompleteHarvest"/>
        <drop event="Harvest" name="resourceCloth" count="1" tag="WasteTreasuresCompleteHarvest"/>
        <drop event="Harvest" name="resourceBone" count="1" tag="WasteTreasuresCompleteHarvest"/>
        <drop event="Harvest" name="oldCash" count="1,7" tag="WasteTreasuresCompleteHarvest"/>
    </append>

    <!-- Corpse HP should also be applied directly to real zombie classes. -->
    <append xpath="/entity_classes/entity_class[starts-with(@name,'zombie') and not(contains(@name,'Template'))]">
        <property name="DeadBodyHitPoints" value="250"/>
    </append>
</configs>
